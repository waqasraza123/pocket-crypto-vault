{
  "name": "goal-vault-base-usdc",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.11.1",
  "scripts": {
    "dev": "pnpm --filter @goal-vault/mobile start",
    "dev:api": "pnpm --filter @goal-vault/api dev",
    "dev:web": "pnpm --filter @goal-vault/mobile web",
    "dev:ios": "pnpm --filter @goal-vault/mobile ios",
    "dev:android": "pnpm --filter @goal-vault/mobile android",
    "test": "turbo run test",
    "test:ts": "pnpm --filter @goal-vault/api --filter @goal-vault/mobile --filter @goal-vault/api-client --filter @goal-vault/contracts-sdk test",
    "test:contracts": "pnpm --filter @goal-vault/contracts test",
    "typecheck": "turbo run typecheck",
    "verify:ci": "pnpm typecheck && pnpm test:ts && pnpm test:contracts",
    "verify:mobile:web": "pnpm --filter @goal-vault/mobile exec expo export --platform web --output-dir ../../dist/web",
    "verify:mobile:ios": "pnpm --filter @goal-vault/mobile exec expo export --platform ios --output-dir ../../dist/ios",
    "verify:mobile:android": "pnpm --filter @goal-vault/mobile exec expo export --platform android --output-dir ../../dist/android",
    "verify:release": "pnpm typecheck && pnpm verify:mobile:web && pnpm verify:mobile:ios && pnpm verify:mobile:android"
  },
  "devDependencies": {
    "@types/node": "^24.9.1",
    "tsx": "^4.20.6",
    "turbo": "^2.5.8",
    "typescript": "^5.9.3"
  },
  "pnpm": {
    "overrides": {
      "lightningcss": "1.30.1"
    }
  }
}
