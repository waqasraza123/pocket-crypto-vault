{
  "name": "pocket-vault-base-usdc",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.11.1",
  "scripts": {
    "dev": "pnpm --filter @pocket-vault/mobile start",
    "dev:api": "pnpm --filter @pocket-vault/api dev",
    "dev:web": "pnpm --filter @pocket-vault/mobile web",
    "dev:ios": "pnpm --filter @pocket-vault/mobile ios",
    "dev:android": "pnpm --filter @pocket-vault/mobile android",
    "api:data:restore": "node scripts/restore-api-data-snapshot.mjs",
    "api:data:snapshot": "node scripts/create-api-data-snapshot.mjs",
    "api:database:export": "node scripts/write-api-managed-database-export.mjs",
    "api:database:import:plan": "node scripts/write-api-managed-database-import-plan.mjs",
    "api:database:parity": "node scripts/write-api-managed-database-parity-plan.mjs",
    "api:database:plan": "node scripts/write-api-managed-database-plan.mjs",
    "api:database:runtime:plan": "node scripts/write-api-managed-database-runtime-plan.mjs",
    "api:database:schema": "node scripts/write-api-managed-database-schema.mjs",
    "api:database:schema:apply": "node scripts/apply-api-managed-database-schema.mjs",
    "api:database:import:execute": "node scripts/execute-api-managed-database-import.mjs",
    "api:database:parity:execute": "node scripts/execute-api-managed-database-parity.mjs",
    "api:preflight": "pnpm --filter @pocket-vault/api preflight",
    "api:traffic:plan": "node scripts/write-api-traffic-plan.mjs",
    "api:traffic:vercel": "node scripts/write-vercel-api-traffic-command.mjs",
    "api:traffic:vercel:execute": "node scripts/execute-vercel-api-traffic.mjs",
    "beta:data:retention": "node scripts/write-beta-data-retention-plan.mjs",
    "beta:readiness": "node scripts/write-beta-readiness-plan.mjs",
    "beta:support:export": "node scripts/write-beta-support-export.mjs",
    "test": "turbo run test",
    "test:ts": "pnpm --filter @pocket-vault/api --filter @pocket-vault/mobile --filter @pocket-vault/api-client --filter @pocket-vault/contracts-sdk test",
    "test:contracts": "pnpm --filter @pocket-vault/contracts test",
    "typecheck": "turbo run typecheck",
    "deploy:contracts:broadcast": "pnpm --filter @pocket-vault/contracts deploy:broadcast",
    "deploy:contracts:manifest": "pnpm --filter @pocket-vault/contracts deploy:manifest",
    "deploy:contracts:simulate": "pnpm --filter @pocket-vault/contracts deploy:simulate",
    "image:api:build": "docker build -f apps/api/Dockerfile -t pocket-vault-api:local .",
    "release:manifest": "node scripts/write-release-manifest.mjs",
    "smoke:production-v1": "node scripts/run-production-v1-smoke-checks.mjs",
    "verify:ci": "pnpm typecheck && pnpm test:ts && pnpm test:contracts",
    "verify:mobile:web": "pnpm --filter @pocket-vault/mobile exec expo export --platform web --output-dir ../../dist/web",
    "verify:mobile:ios": "pnpm --filter @pocket-vault/mobile exec expo export --platform ios --output-dir ../../dist/ios",
    "verify:mobile:android": "pnpm --filter @pocket-vault/mobile exec expo export --platform android --output-dir ../../dist/android",
    "verify:release": "pnpm typecheck && pnpm verify:mobile:web && pnpm verify:mobile:ios && pnpm verify:mobile:android"
  },
  "devDependencies": {
    "@types/node": "^24.9.1",
    "tsx": "^4.20.6",
    "turbo": "^2.5.8",
    "typescript": "^5.9.3"
  },
  "pnpm": {
    "overrides": {
      "lightningcss": "1.30.1"
    }
  }
}
