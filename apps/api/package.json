    "@pocket-vault/contracts-sdk": "workspace:*",
    "@pocket-vault/shared": "workspace:*",
    "@neondatabase/serverless": "^1.1.0",
    "fastify": "^5.6.1",
    "pg": "^8.20.0",
    "tsx": "^4.20.6",
    "viem": "^2.38.5",
    "ws": "^8.20.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/node": "^24.9.1"
  }
}
